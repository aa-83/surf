        rehydrate-data="{&quot;updated&quot;:1615916022000,&quot;messages&quot;:[{&quot;id&quot;:&quot;1.15420319&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T17:33:42Z&quot;,&quot;title&quot;:&quot;Danmark vil bekjempe pirater&quot;,&quot;lead&quot;:&quot;Danmark sender en fregatt til Guineabukta i det sørvestlige Afrika for å bekjempe piratvirksomhet, opplyser forsvarsdepartementet. I fjor ble rundt 140 sjøfolk bortført i Guineabukta. Oppdraget skal starte i november og vare i fem måneder. &quot;,&quot;time&quot;:&quot;18:33&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Piratangrep&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/piratangrep-1.11317444&quot;}]},{&quot;id&quot;:&quot;1.15420318&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T17:24:43Z&quot;,&quot;title&quot;:&quot;Strengere tiltak på Stord&quot;,&quot;lead&quot;:&quot;Stord kommune innfører skjenkestopp, påbud om hjemmekontor og stans av idretts- og fritidsaktiviteter.\nDe nye tiltakene ble enstemmig vedtatt i et formannskapsmøte tirsdag, skriver &lt;a href=\&quot;https://www.sunnhordland.no/nyhende/dette-er-dei-nye-tiltaka-i-stord-kommune/\&quot;&gt;Sunnhordland&lt;/a&gt;.\nTiltakene vil gjelde fra natt til onsdag og til fredag 9. april.\nMandag ble det påvist 19 nye koronatilfeller i kommunen. Det førte til at det tirsdag ble innført hjemmeskole for grunnskolen. Dette vil gjelde inntil videre.\nHøgskolen på Vestlandets campus i kommunen må stenge lokalene, mens videregående skoler skal følge rødt nivå.\nI tillegg stenger Stord kommune også treningssentre, svømmehaller, museer, kinoer og konsertsteder. Det er satt begrensninger for antall personer på arrangement og i private sammenkomster. (NTB)&quot;,&quot;time&quot;:&quot;18:24&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Koronaviruset&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/koronaviruset-1.14855584&quot;}]},{&quot;id&quot;:&quot;1.15420315&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T17:22:32Z&quot;,&quot;title&quot;:&quot;Flere titalls drept i Niger &quot;,&quot;lead&quot;:&quot;I Niger ble flere titalls mennesker drept i flere angrep på mandag. Angrepene skjedde nær grensen til Mali, i et område hvor jihadister er et problem. I et angrep på en buss, blw rundt 20 mennesker drept. Deretter ble rundt 30 mennesker drept i angrep på landsbyer. &quot;,&quot;time&quot;:&quot;18:22&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Niger&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/niger-1.12710253&quot;}]},{&quot;id&quot;:&quot;1.15420312&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T17:13:42Z&quot;,&quot;title&quot;:&quot;408 koronadødsfall i Frankrike&quot;,&quot;lead&quot;:&quot;Frankrike rapporterer om 408 nye koronadødsfall det siste døgnet. Totalt har 91.170 personer i landet mistet livet etter at de fikk covid-19. Det siste døgnet er det registrert 29.975 nye smittede. &quot;,&quot;time&quot;:&quot;18:13&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Koronaviruset&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/koronaviruset-1.14855584&quot;}]},{&quot;id&quot;:&quot;1.15420263&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T17:08:09Z&quot;,&quot;title&quot;:&quot;Treningsstopp for toppklubbene&quot;,&quot;lead&quot;:&quot;Norges Fotballforbund har informert alle toppklubbene i fotball i Viken, om at all toppidrett har blitt stengt ned. Det rammer Strømsgodset, Mjøndalen og kvinnelaget til Hønefoss, som dermed ikke får trent sammen før tiltakene eventuelt oppheves 11. april, melder &lt;a href=\&quot;https://nyheter.ntb.no/ntbWeb/search.action#service=news;id=17591062;ntbid=NTB57d087bb-54f9-48e9-abb7-4b7cf770d09e\&quot;&gt;NTB&lt;/a&gt;&quot;,&quot;time&quot;:&quot;18:08&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Koronaviruset&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/koronaviruset-1.14855584&quot;}]},{&quot;id&quot;:&quot;1.15420295&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T16:56:09Z&quot;,&quot;title&quot;:&quot;EU-sanksjoner mot Myanmar&quot;,&quot;lead&quot;:&quot;EU vil neste uke vedta sanksjoner mot kuppmakerne i Myanmar. Det vil skje på et møte mellom utenriksministrene. Det sier Frankrikes utenriksminister Jean-Yves Le Drian, melder Reuters. &quot;,&quot;time&quot;:&quot;17:56&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Myanmar&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/myanmar-1.15354134&quot;}]},{&quot;id&quot;:&quot;1.15420282&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T16:39:32Z&quot;,&quot;title&quot;:&quot;Strengere tiltak på Haugalandet&quot;,&quot;lead&quot;:&quot;Regjeringen innfører strenge regionale tiltak for sju nye kommuner på Haugalandet, skiver de i en pressemelding. Kommunene som får et særlig høyt tiltaksnivå (nivå A) er Bokn, Haugesund, Karmøy, Sveio, Tysvær, Utsira og Vindafjord.\nKommunene har høy smitte og vedtaket fra regjeringen kommer etter ønske fra kommunene, og anbefaling fra statsforvalteren, Helsedirektoratet og Folkehelseinstituttet.\nDe nye tiltakene gjelder fra natt til onsdag til og med 11. april.&quot;,&quot;time&quot;:&quot;17:39&quot;,&quot;emphasis&quot;:true,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Koronaviruset&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/koronaviruset-1.14855584&quot;}]},{&quot;id&quot;:&quot;1.15420278&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T16:26:12Z&quot;,&quot;title&quot;:&quot;– Går bra å utsette andre dose&quot;,&quot;lead&quot;:&quot;Folk som inntil videre ikke får satt sin andre dose med AstraZeneca-vaksine, trenger ikke å bekymre seg for mangel på korona-beskyttelse, mener tysk ekspert.\nAstraZeneca-vaksinen settes normalt i to doser med ni til tolv ukers mellomrom.\n– Ut fra det vi vet, er det ikke noe problem å utsette den andre vaksineringen, sier Stefan Kaufmann i Max Planck-instituttet for infeksjonsbiologi i Berlin.\n– Beskyttelsen som bygges opp etter den første vaksineringen, bør kunne vare i minst seks måneder, tilføyer Kaufmann.(NTB)&quot;,&quot;time&quot;:&quot;17:26&quot;,&quot;emphasis&quot;:false,&quot;compilations&quot;:[{&quot;title&quot;:&quot;Koronaviruset&quot;,&quot;url&quot;:&quot;https://www.nrk.no/nyheter/koronaviruset-1.14855584&quot;}]},{&quot;id&quot;:&quot;1.15420163&quot;,&quot;type&quot;:&quot;Teaser&quot;,&quot;published&quot;:&quot;2021-03-16T16:24:14Z&quot;,&quot;title&quot;:&quot;Sorgenfri og Erlik slår seg sammen&quot;,&quot;lead&quot;:&quot;Stiftelsene bak gatemagasinene Sorgenfri og =Oslo slår seg sammen. Sammenslåingen gir muligheter for en betydelig innsparinger i administrasjonen av Sorgenfri i Trondheim. Dette skriver stiftelsene i en felles pressemelding.&quot;,&quot;time&quot;:&quot;17:24&quot;,&quot;emphasis&quot;:false}]}"
