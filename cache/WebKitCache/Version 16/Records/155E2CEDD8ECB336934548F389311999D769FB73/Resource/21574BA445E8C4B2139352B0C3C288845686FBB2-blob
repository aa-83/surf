            var language = getLanguageCode();

            if (term === "") {
                suggestionsInit();
            } else {
                $.ajax({
                    type: "GET",
                    data:
                    {
                        "countryCode": country,
                        "languageCode": language,
                        "fulltext": term
                    },
                    url: suggestionUrl,
                    contentType: "application/json",
                    success: suggestionsHandler
                });

            }
	    }

