var MarketSelectorObj = {
    defaultFirstOption : '<option hidden="" style="display:none" disabled="" selected="" value="">-- select an option --</option>',
    marketInfo : {},
    countryCode : "",
    languageCode : "",
    airportCode : "",
    selectedCountryCode : "",
    selectedLanguageCode : "",
    selectedAirportCode : "",
    countrySelector : "#market-selectors #location",
    languageSelector : "#market-selectors #language",
    airportSelector : "#market-selectors #airport",


    handleOnReady : function(){
        var thisObj = this;
        thisObj.marketInfo = JSON.parse($('#market-selectors').attr('data-market-info') || "{}");

        thisObj.countryCode = getCountryCode();
        thisObj.selectedCountryCode = getCountryCode();
        thisObj.languageCode = getLanguageCode();
        thisObj.selectedLanguageCode = getLanguageCode();
        thisObj.airportCode = getOriginCookie();
        thisObj.selectedAirportCode = getOriginCookie();

        var countryOptions = [];

		if(thisObj.marketInfo.sites){
			Object.keys(thisObj.marketInfo.sites).forEach(function(key){
				var item = thisObj.marketInfo.sites[key];
				countryOptions.push("<option value='"+item.countryCode+"' >"+item.countryName+"</option>");
			});
		}		
        $(thisObj.countrySelector).empty().append(countryOptions);
        $(thisObj.countrySelector)[0].value = thisObj.countryCode;
        $(thisObj.countrySelector).parent().find(".selected-value").text(thisObj.marketInfo.sites[thisObj.countryCode].countryName);        
        thisObj.updateMarketOptions();

    },

    handleCountryChange : function(event){
        var thisObj = this;
        thisObj.selectedCountryCode = event.target.value;
        $(event.target).prev('.selected-value').text(event.target.options[event.target.selectedIndex].text);

        thisObj.selectedLanguageCode = "";
        thisObj.selectedAirportCode = "";

        thisObj.updateMarketOptions();
        thisObj.toggleButton();
    },

    handleLanguageChange : function(event){
        var thisObj = this;
        thisObj.selectedLanguageCode = event.target.value;

        $(event.target).prev('.selected-value').text(event.target.options[event.target.selectedIndex].text);
        thisObj.toggleButton();
    },

    handleAirportChange : function(event){
        var thisObj = this;
        thisObj.selectedAirportCode = event.target.value;

        $(event.target).prev('.selected-value').text(event.target.options[event.target.selectedIndex].text);
        thisObj.toggleButton();
    },

    updateMarketOptions : function(){
        var thisObj = this;
        var languageOptions = [];
        var airportOptions = [];
        var selectedMarketObj = thisObj.marketInfo.sites[thisObj.selectedCountryCode];
        selectedMarketObj.languages.forEach(function(lang){
            languageOptions.push("<option homePath='"+lang.homePath+"' value='"+lang.languageCode+"' >"+lang.language+"</option>");
        });
        selectedMarketObj.origins.forEach(function(org){
            airportOptions.push("<option value='"+org.airportCode+"' >"+org.cityName+"</option>");
        });        
        $(thisObj.languageSelector).empty().append(languageOptions);
        $(thisObj.airportSelector).empty().append(airportOptions);

        if(thisObj.countryCode === thisObj.selectedCountryCode){            
            $(thisObj.languageSelector)[0].value = thisObj.languageCode;
            thisObj.selectedLanguageCode = thisObj.languageCode;
            $(thisObj.airportSelector)[0].value = thisObj.airportCode;
            thisObj.selectedAirportCode = thisObj.airportCode;

            if(!thisObj.airportCode || $(thisObj.airportSelector)[0].selectedIndex < 0){
               $(thisObj.airportSelector)[0].options.selectedIndex = 0;
                thisObj.selectedAirportCode = $(thisObj.airportSelector)[0].options[0].value;
            }

        } else {            
            $(thisObj.languageSelector)[0].options.selectedIndex = 0;
            thisObj.selectedLanguageCode = $(thisObj.languageSelector)[0].options[0].value;            
            $(thisObj.airportSelector)[0].options.selectedIndex = 0;
            thisObj.selectedAirportCode = $(thisObj.airportSelector)[0].options[0].value;

        }        
        if(!getOriginCookie()){
            writeOriginCookie(thisObj.selectedAirportCode);
        }
        $($(thisObj.languageSelector)).prev(".selected-value").text($(thisObj.languageSelector)[0].options[$(thisObj.languageSelector)[0].selectedIndex].text);
        
        $($(thisObj.airportSelector)).prev(".selected-value").text($(thisObj.airportSelector)[0].options[$(thisObj.airportSelector)[0].selectedIndex].text);
        
    },

    toggleButton : function(){
        var thisObj = this;
        if((thisObj.countryCode === thisObj.selectedCountryCode &&
            thisObj.languageCode === thisObj.selectedLanguageCode &&
            thisObj.airportCode === thisObj.selectedAirportCode) || !(
            thisObj.selectedCountryCode &&
            thisObj.selectedLanguageCode &&
            thisObj.selectedAirportCode)){
            $("#market-selectors button").addClass('disabled');
            $("#market-selectors button").attr('tabindex', '-1');
        } else{
            $("#market-selectors button").removeClass('disabled');
            $("#market-selectors button").attr('tabindex', '0');
        }
    },

    applyChange : function(event){
        var thisObj = this;        
        writeOriginCookie(thisObj.selectedAirportCode);
        
        if( thisObj.countryCode === thisObj.selectedCountryCode && thisObj.languageCode === thisObj.selectedLanguageCode ){
            $(document).trigger( "originChange", [thisObj.selectedAirportCode]);
            thisObj.airportCode = thisObj.selectedAirportCode;
            thisObj.toggleButton();
        } else {

            var url = ($($(thisObj.languageSelector)[0].options[$(thisObj.languageSelector)[0].selectedIndex]).attr('homePath'));
            thisObj.loadNewMarketOrLanguage(url);
        }

    },

    loadNewMarketOrLanguage : function(selectedHomePath){
        var url = selectedHomePath;
        if (getSSOCookie() !== null) {
            url = "/bin/sso/redirect?redirectUrl=" + encodeURIComponent(selectedHomePath);
        }
		window.location.href = url + "?_source=marketselector";
    }

}

