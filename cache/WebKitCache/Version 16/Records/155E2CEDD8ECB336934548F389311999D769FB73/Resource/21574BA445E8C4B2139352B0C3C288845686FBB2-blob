    getCookieOverlayContent: function(){

        if($('#cookie-modal-window').attr('data-loaded') === 'true'){
            return ;
        }

        //var href = '/'+$('.cookies-bar .wrapper a').attr('href').replace('en/');
        //var href = $('.cookies-bar .wrapper .cookie-content a:not(.morelink)').attr('data-url');
        var href = $('.cookies-bar .wrapper .cookies-info').attr('data-link-path');
        if(href.lastIndexOf('/')+1 === href.length){
            href = href.substring(0, href.length-1);
        }
        
        var pageLink = "";

        if(typeof getExternalizedRootPage == "undefined"){
            var locationUrl = location.protocol + "//" + location.hostname + location.pathname;
            locationUrl = locationUrl.substring(0, locationUrl.lastIndexOf("/"));
            locationUrl = locationUrl.replace('/classic','');
            locationUrl = locationUrl.replace('/book','');
            pageLink = locationUrl + href +'.content.hxtml'

        } else {
            pageLink = getExternalizedRootPage().replace('/classic','') + href +'.content.html'
        }
        
        $.ajax({
            method: "GET",
            dataType: "html",
            url: pageLink,
            success: function(data) {
                $('#cookie-modal-window').attr('data-loaded','true');
                $('#cookie-modal-window .modal-content').append(data);
                $('#cookie-modal-window .modal-content .breadcrumb').hide();
                $("#cookie-policy-header").addClass("auto-focus");
                $("#cookie-policy-header").focus();
                CookieNotificationObj.removeAutoFocus();
                CookieNotificationObj.cookieOverlayFocus();
            },
            error: function(jqXHR, textStatus, errorThrown) {
                console.log("Cookie notification : Error fetching page : "+errorThrown);
            }  
        });
    },

    removeAutoFocus: function() {
         $("#cookie-policy-header").focusin(function(){

            $(this).addClass("auto-focus");

        })
        $("#cookie-policy-header").focusout(function(){

            $(this).removeClass("auto-focus");

        })
    },

    acknowledgeCookie: function() {
       // $('.cookies-bar').css("display", "none").toggle();
        $('.cookies-bar').hide();
