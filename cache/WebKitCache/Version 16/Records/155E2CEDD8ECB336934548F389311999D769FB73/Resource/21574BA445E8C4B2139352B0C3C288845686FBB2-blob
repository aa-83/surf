/** Setters **/

function writeCookie(cookieName, cookieValue, cookiePersistence){

    if(cookiePersistence === COOKIE_USER_PERSISTENCE){
        document.cookie =
            cookieName + "=" + encodeURIComponent(cookieValue) +
            "; max-age=" + cookiePersistence +
            "; path=/" ;
    } else {
                document.cookie =
            cookieName + "=" + encodeURIComponent(cookieValue) +
            "; path=/" ;
    }
}

