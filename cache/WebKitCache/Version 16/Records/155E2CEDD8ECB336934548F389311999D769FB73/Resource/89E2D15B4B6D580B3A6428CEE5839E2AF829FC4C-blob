[{"id":170504,"value":0.5,"lifetime":"short","liveblogTitle":"Koronautbruddet","liveblogEntriesCount":8203,"liveblogIsClosed":false,"title":"Regjeringen innfører strenge tiltak i Sveio og seks andre kommuner","content":{"components":[{"type":"text","value":"Regjeringens strengeste tiltaksnivå innføres i syv kommuner på Haugalandet. Tiltakene gjelder fra midnatt og til søndag 11. april.","markup":[]},{"type":"text","value":"– Det er stigende smitte med den engelske virusvarianten i flere av kommunene i området, og de melder om at situasjonen er utfordrende og uoversiktlig. Kommunene har derfor bedt om at regjeringen innfører regionale tiltak slik at de kan få kontroll over smitten, sier helse- og omsorgsminister Bent Høie (H) i en pressemelding.","markup":[]},{"type":"text","value":"Tiltakene gjelder for kommunene Sveio i Vestland og Bokn, Haugesund, Karmøy, Tysvær, Utsira og Vindafjord i Rogaland fylke.","markup":[]},{"type":"related-article","articleUrl":"https://www.bt.no/nyheter/innenriks/i/86RrjE/regjeringen-innfoerer-strenge-regionale-tiltak-paa-haugalandet"},{"type":"related-article","articleUrl":"https://www.bt.no/nyheter/lokalt/i/OQWwVb/kommunene-paa-haugalandet-ber-om-strenge-regionale-tiltak"}]},"createdAt":"17:57","teaser":"Regjeringen innfører strenge tiltak i Sveio og seks andre kommuner","pinnedEntryUrl":"https://www.bt.no/nyheter/direkte/i/3Jd0RL/siste-nytt-om-korona?pinnedEntry=170504"},{"id":170503,"value":0.5,"lifetime":"short","liveblogTitle":"Koronautbruddet","liveblogEntriesCount":8203,"liveblogIsClosed":false,"title":"Ingen nye alvorlige bivirkninger etter Astrazeneca-vaksine i Norge","content":{"components":[{"type":"image","byline":{"title":"Stian Lysberg Solum / NTB"},"caption":{"value":"Medisinsk fagdirektør Steinar Madsen i Statens legemiddelverk."},"cropRatio":{"x":0,"y":0,"unit":"px","cropX":0,"cropY":0,"label":"16:9","width":519,"aspect":1.7777777777777777,"height":291.9375,"cropWidth":3020,"cropHeight":1698.46875,"isCropAdjusted":true},"imageAsset":{"id":"aaae8e8326e7c20b5641faad0bb10bbd","crop":"16:9","urls":[{"url":"https://imbo.vgc.no/users/bt/images/aaae8e8326e7c20b5641faad0bb10bbd?t%5B%5D=crop%3Awidth%3D3020%2Cheight%3D1698%2Cx%3D0%2Cy%3D0&t%5B%5D=maxSize%3Awidth%3D270&publicKey=bt-w&accessToken=cdbbcad4a050e5920d95dad9e35c988a2b74d13c62fc93db56f0a2811075cd70","width":270,"default":false},{"url":"https://imbo.vgc.no/users/bt/images/aaae8e8326e7c20b5641faad0bb10bbd?t%5B%5D=crop%3Awidth%3D3020%2Cheight%3D1698%2Cx%3D0%2Cy%3D0&t%5B%5D=maxSize%3Awidth%3D480&publicKey=bt-w&accessToken=a1326e6135ff5f8b225b29a01f830731bebb52ee4f6ee5027aa870d570ac6e94","width":480,"default":false},{"url":"https://imbo.vgc.no/users/bt/images/aaae8e8326e7c20b5641faad0bb10bbd?t%5B%5D=crop%3Awidth%3D3020%2Cheight%3D1698%2Cx%3D0%2Cy%3D0&t%5B%5D=maxSize%3Awidth%3D640&publicKey=bt-w&accessToken=8c6491fa73c5d6c4dc0baf34c7171200ae286d628572c0d08761a018665d9ce2","width":640,"default":true}]}},{"type":"text","value":"Det er tirsdag ikke rapportert inn nye tilfeller av alvorlige bivirkninger av folk som har fått Astrazeneca-vaksinen i Norge, opplyser Statens legemiddelverk.","markup":[]},{"type":"text","value":"– Det har foreløpig ikke dukket opp noe nytt i dag, sier medisinsk fagdirektør Steinar Madsen i Statens legemiddelverk tirsdag ettermiddag.","markup":[]},{"type":"text","value":"Én av de tre helsearbeiderne som nylig ble innlagt på Rikshospitalet etter å ha fått AstraZeneca-vaksinen, døde søndag. Det er ennå ikke påvist noen sammenheng mellom vaksinen og de alvorlige bivirkningene, men all bruk av vaksinen er likevel satt på vent i Norge og en rekke andre land.","markup":[]},{"type":"text","value":"– Vi kan ikke bekrefte at det er en sammenheng med de få alvorlige bivirkningene i Norge, men vi kan heller ikke utelukke det. Så foreløpig så er dette åpent, sier Madsen.","markup":[]},{"type":"related-article","articleUrl":"https://www.bt.no/nyheter/innenriks/i/Gawo5Q/ingen-nye-alvorlige-bivirkninger-etter-astrazeneca-vaksine-i-norge"},{"type":"related-article","articleUrl":"https://www.bt.no/nyheter/lokalt/i/qAmj3m/ein-helsearbeidar-innlagd-med-blodpropp-paa-haukeland"}]},"createdAt":"17:20","teaser":"Ingen nye alvorlige bivirkninger etter Astrazeneca-vaksine i Norge","pinnedEntryUrl":"https://www.bt.no/nyheter/direkte/i/3Jd0RL/siste-nytt-om-korona?pinnedEntry=170503"},{"id":170494,"value":0.5,"lifetime":"short","liveblogTitle":"Koronautbruddet","liveblogEntriesCount":8203,"liveblogIsClosed":false,"title":"Tre nye smittede i Sveio","content":{"components":[{"type":"text","value":"Sveio kommune opplyser tirsdag at det er tre nye smittede i kommunen. Tidligere tirsdag gikk kommunen ut og ba om forsterkede smitteverntiltak sammen med resten av Haugalandet.","markup":[]},{"type":"related-article","articleUrl":"https://www.bt.no/nyheter/lokalt/i/OQWwVb/kommunene-paa-haugalandet-ber-om-strenge-regionale-tiltak"}]},"createdAt":"15:30","teaser":"Tre nye smittede i Sveio","pinnedEntryUrl":"https://www.bt.no/nyheter/direkte/i/3Jd0RL/siste-nytt-om-korona?pinnedEntry=170494"},{"id":170493,"value":0.5,"lifetime":"short","liveblogTitle":"Koronautbruddet","liveblogEntriesCount":8203,"liveblogIsClosed":false,"title":"To nye smittet i Øygarden – bekrefter britisk virusvariant","content":{"components":[{"type":"text","value":"To nye personer har fått påvist koronasmitte i Øygarden kommune tirsdag.","markup":[]},{"type":"text","value":"18 personer er nå i isolasjon. Øygarden kommune bekrefter at de som har fått korona i kommunen de siste dagene, har fått den britiske virusvarianten.","markup":[]}]},"createdAt":"15:24","teaser":"To nye smittet i Øygarden – bekrefter britisk virusvariant","pinnedEntryUrl":"https://www.bt.no/nyheter/direkte/i/3Jd0RL/siste-nytt-om-korona?pinnedEntry=170493"}]