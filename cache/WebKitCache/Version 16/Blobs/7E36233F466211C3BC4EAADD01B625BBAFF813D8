/*Burger menu animation start*/
.mobile-primary-menu.menu-animate-in {
    left: 0;
    display: block;  
    -webkit-animation-name: sneak-in;
    animation-name: sneak-in;
    -webkit-animation-duration: 140ms;
    animation-duration: 140ms;
    -webkit-animation-timing-function: ease-in-out;
    animation-timing-function: ease-in-out;
    -webkit-animation-direction: normal;
    animation-direction: normal;
    -webkit-animation-delay: 0s;
    animation-delay: 0s;
}

.mobile-primary-menu.menu-animate-out {
    left: 100%;  
    -webkit-animation-name: sneak-out;
    animation-name: sneak-out;
    -webkit-animation-duration: 120ms;
    animation-duration: 120ms;
    -webkit-animation-timing-function: ease-in-out;
    animation-timing-function: ease-in-out;
    -webkit-animation-direction: normal;
    animation-direction: normal;
    -webkit-animation-delay: 0s;
    animation-delay: 0s;
}

@keyframes sneak-in {
    0% {
        opacity: 0;
        left: 100%;
        -webkit-transform: translateX(100%,0);
        -ms-transform: translateX(100%,0);
        transform: translateX(100%,0);
        -webkit-animation-timing-function: ease-in-out;
        animation-timing-function: ease-in-out;
    } 

    100% {
        opacity: 1;
        left: 0;
        -webkit-transform: translateX(0,0);
        -ms-transform: translateX(  0,0);
        transform: translateX(0,0);
        -webkit-animation-timing-function: ease-in-out;
        animation-timing-function: ease-in-out;
    }
}

@keyframes sneak-out {
    0% {
        opacity: 1;
        left: 0;
        -webkit-transform: translateX(0,0);
        -ms-transform: translateX(0,0);
        transform: translateX(0,0);
        -webkit-animation-timing-function: ease-in-out;
        animation-timing-function: ease-in-out;
    }

    90% {
        left: 90%;
        opacity: .2;
        -webkit-transform: translateX(90%,0);
        -ms-transform: translateX(90%,0);
        transform: translateX(90%,0);
    }

    100% {       
        left: 100%;
        -webkit-transform: translateX(100%,0);
        -ms-transform: translateX(100%,0);
        transform: translateX(100%,0);
        -webkit-animation-timing-function: ease-in-out;
        animation-timing-function: ease-in-out;       
        opacity: 0;
    }
}

