/********************/
.sas-footer {
    width: 100%;
    background: #f4f4f4;
    margin-top: 20px;
    padding: 20px 0 0 0;
    overflow: hidden;
}

.footer-inner li {
    float: left;
    width: 33.333%;
}
.footer-inner li li { width: 100%;}
.footer-inner li li:last-child {margin-bottom: 30px;}
.footer-inner li .footer-links:last-child li:last-child {margin-bottom: 0;}

.sas-footer .footer-inner a {
    color: #3f3d3a;
    line-height: 32px;
}
.sas-footer .bottom-footer {
    background: #009;
    clear: both;
    min-height: 88px;
    padding: 35px 0 0 0;
    width: 100%;
    float: left;
}

.sas-footer .bottom-footer li {
    display: inline-block;
    padding-right: 20px;
}

.sas-footer .bottom-footer a { color: #fff;}

.sas-footer .help-contact {
    margin-top: 30px;
    float: left;
}

.sas-footer .dropdown-native {
    border-radius: 4px;
    margin-bottom: 15px;
}

.sas-footer .dropdown-native .selected-value {
    color: #3f3d3a;
    font-size: 16px;
    text-transform: capitalize;
}

.social-networks a {
    margin: 0 18px;
    position: relative;
    overflow: visible;
}

.social-networks a.follow-us:after{
    background: url('../../../etc.clientlibs/flysas/clientlibs/common/clientlibs-resources/resources/images/sprite-ia.svg') no-repeat -134px -1198px;
}
#mainBodyClass .social-networks a.follow-us:after {
    background: url('../../../etc.clientlibs/flysas/clientlibs/common/clientlibs-resources/resources/images/sprite-ia.svg') no-repeat -134px -1198px !important;
}
.social-networks a:after {
    content: '';
    width: 10px;
    height: 13px;
    bottom: 14px;
    right: -19px;
    display: inline-block;
    position: absolute;
}

.social-networks a.follow-us {
    margin: 3px 30px 0 0;
    float: left;
    padding-right: 6px;
}

.social-networks a.follow-us:after { bottom: 4px;}

.social-networks { position: relative; }

.social-networks:before {
    content: '';
    border-left: 1px solid #fff;
    position: absolute;
    height: 66px;
    width: 2px;
    display: block;
    left: -41px;
    top: -22px;
    opacity: .5;
}

.follow-us-block { display:inline-block; }

.accdr-main,
.dropdown-wrap{ padding: 40px 0 30px 0;}
.dropdown-native select {
    -webkit-appearance: none;
    appearance: none;
}
.copyrights-footer {
    background: #fff;
    min-height: 72px;
    padding: 13px 0 14px 0;
    text-align: center;
    width: 100%;
    float: left;
    clear: both;
}

.copyrights-footer p {
    margin: 14px 0;
}

.dropdown-native.white .icon-down:before {display: none;}

@media (max-width: 991px) {
    .icon-star-alliance {
            margin: 0 auto;
            float: none !important;
    }
}

@media (min-width: 768px) {
    .sas-footer .content { display:block !important;}
    
    .sas-footer .wrapper { 
        padding: 0 8px;
        float: none;
    }
    
    .footer {
        background: none;
    }
}
@media (max-width: 767px) {

    .follow-us-block {
        display: block;
        width: 100%;
        float: left;
        text-align: center;
        padding: 0 0 20px 0;
