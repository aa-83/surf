    acknowledgeCookie: function() {
       // $('.cookies-bar').css("display", "none").toggle();
        $('.cookies-bar').hide();
        CookieNotificationObj.writeAckCookie();
        date = new Date();
        date.setTime(date.getTime() + (3600 * 1000 * 24 * 365));
        expires = '; expires=' + date.toUTCString();
        document.cookie = '_cookienew=acknowledged' + expires + ';' + 'path=/';

        $('#cookie-modal-window').hide();
        $('#cookie-modal-window').closest('body').removeClass('overflow-hidden modal-open');
        $('#cookie-modal-window').closest('html').removeClass('overflow-hidden');
        CookieNotificationObj.gtmCookieTracking();
    },

    gtmCookieTracking: function() {

        var checkboxVal = $('#personalization-checkbx').is(":checked");

        date = new Date();
        date.setTime(date.getTime() + (3600 * 1000 * 24 * 365));
        expires = '; expires=' + date.toUTCString();
        document.cookie = '_cookiepersonalization='+ checkboxVal + expires + ';' + 'path=/';

        // SAS - Integrated Marketing - Tracking Consent - User Opted (In for:true / out of:false) Personalization
        window.sasD360DataLayer = window.sasD360DataLayer || [];
        window.sasD360DataLayer.push(
            {
                'event': 'sas.trackingconsent.update',
                'trackingconsent': {
                    'personalization':checkboxVal
                }   
            }
        );
    },

    getAckCookie: function() {
        var cookie_string = CookieNotificationObj.get_cookie("_cookienew");
        return cookie_string;
    },
    
    getPrzCookie: function() {
        var cookie_string = CookieNotificationObj.get_cookie("_cookiepersonalization");
        return cookie_string;
    },

    get_cookie: function ( cookie_name ){
        var re = new RegExp(cookie_name + "=([^;]+)");
        var value = re.exec(document.cookie);
        return (value != null) ? unescape(value[1]) : null;
    },

    writeAckCookie: function(){
        CookieNotificationObj.writeCookie("_cookienew", "acknowledged", 63072000);
    },

    writeCookie: function(cookieName, cookieValue, cookiePersistence){
        document.cookie =
            cookieName + "=" + encodeURIComponent(cookieValue) +
            "; max-age=" + cookiePersistence +
            "; path=/" ;
    },

