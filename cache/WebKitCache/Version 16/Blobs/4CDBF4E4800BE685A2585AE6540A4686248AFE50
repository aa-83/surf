function checkHomepage(){
    var isHomepage = false;
    var countryCode = getCountryCode();
    var languageCode = getLanguageCode();

    var path = window.location.pathname;
    var pathArr = path.split('/');
    var pathArrUpdated = [];
    
    for(i=0,x=0; x<pathArr.length; x++){
        if(pathArr[x]!==""){
            pathArrUpdated[i++] = pathArr[x];
        }
    }

    var marketLang = countryCode.toLowerCase()+'-'+languageCode;

    if(pathArrUpdated.length == 0){
        isHomepage = true;
    } else if(pathArrUpdated.length == 1){
        if(pathArrUpdated[0] === languageCode || pathArrUpdated[0] === marketLang){
            isHomepage = true;
        }
    }

    return isHomepage;
}
