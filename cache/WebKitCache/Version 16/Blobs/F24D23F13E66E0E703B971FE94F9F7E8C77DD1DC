    getTribe : function(){
        var tribe;
        if(getCustomerDNACookie()){
            var dnaData=getCustomerDNACookie();
            var dnaTokenArr=dnaData.split(',');
            var customerTribe=(dnaTokenArr[0] || this.defaultTribe);
            var upcomingBookingPNR=dnaTokenArr[1];
            tribe=customerTribe.toLowerCase();
        }
        else{
            tribe=this.defaultTribe;
        }
        return tribe;
    },

    getValueByKey : function(key, tribeObj) {
        var i, defaultStr = "", allTribeStr = "", str="", len = tribeObj.length;
        for (i = 0; i < len; i++) {
            if(!defaultStr){
                defaultStr = tribeObj[i][this.defaultTribe];
                if (defaultStr) {
                    defaultStr = defaultStr.substring(defaultStr.indexOf("/bannerPage"));
                }
            }
            if(!allTribeStr){
                allTribeStr = tribeObj[i][this.allTribe];
                if (allTribeStr) {
                    allTribeStr = allTribeStr.substring(allTribeStr.indexOf("/bannerPage"));
                }
            }
            if(allTribeStr && key !== this.defaultTribe){
                return allTribeStr;
            }
            if (!str) {
                str = tribeObj[i][key];
                if (str) {
                    str = str.substring(str.indexOf("/bannerPage"));
                }
            }
        }
        if (str) {  
            return str;
        }
        return defaultStr;
    },

