        var thisObj = this;
        var pnrNumber = personalisationObj.getPnrFromCookie();

        if(!pnrFlag){
            pnrNumber = '';
        }

        var currObjClassName = "";
        if(pnrNumber){
            currObjClassName = " .reservation-component";
        }else{
            currObjClassName = " .offer-sales-component";
        }

