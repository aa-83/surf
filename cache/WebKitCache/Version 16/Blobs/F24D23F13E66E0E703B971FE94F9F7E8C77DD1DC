function initMultiDesti(newOriginCode) { //declaring initMultiDesti funtion
    var sliderVal = newOriginCode;

    $(".multiple-destination-campaign").each(function() {

        var currObj = $(this).find(".destination-details");

        if(sliderVal !== "slider" || (sliderVal === "slider" && currObj.find('.temp-range').attr("data-reload") === "true")){

            if(sliderVal === "slider"){
                currObj.find('.temp-range').attr("data-reload","false");
                newOriginCode = "";
            }

            var API_OFFERS_LOWPRICE = "offers/flightproduct/lowestFare"; // lpc url
            var baseURL = getApiHost() + API_OFFERS_LOWPRICE;
            var localeHeader = getLanguageCode() + '_'+ getCountryCode();

            var origName = currObj.attr("data-origName") || newOriginCode || getOriginCookie() || defaultOriginCode;

            var destName = currObj.attr("data-destName");
            var tripType = currObj.attr("data-tripType");

			var isWifiEnabled = currObj.attr("data-wifi-enable");
			var wifiPath = currObj.attr("data-wifi-path");

            var pos = getPOS();

            var today = new Date(new Date().getTime() + (1000 * 60 * 60 * 6))
            var x = currObj.attr("data-startDate");
            var startDate;
            if(x === undefined || x==="") {
                startDate = today;
            }else{
                startDate = formatDialogDate(x);
                if(startDate < today) {
                    startDate = today;
                }
            }
            var formatStartDate = getFormattedDateForApi(startDate);

            var y = currObj.attr("data-endDate");
            var endDate;
            if(y === undefined || y==="") {
                endDate = new Date(startDate);
            } else{
                endDate = formatDialogDate(y);
            }
            if(endDate <= startDate) {
                endDate.setDate(startDate.getDate() + 90);
            }
            var formatEndDate = getFormattedDateForApi(endDate);

            currObj.hide();

            if(currObj.attr("data-enable-tempbar")){
                destName = getDestFromSlider(currObj, sliderVal);
            }


            if(origName && destName && tripType){

                var reqData = {
                        "from": origName,
                        "to": destName,
                        "startDate": formatStartDate,
                        "endDate": formatEndDate,
                        "paxType": "ADT",
                        "displayType": "DAY",
                        "pos": pos,
                        "tripType": tripType
                    };

                if(isWifiEnabled){
                    reqData["cepId"] = pos+"_INAIR";
                }

                $.ajax({
                    url: baseURL,
                    data: reqData ,
                    beforeSend: function (jqXHR, settings) {
                        jqXHR.setRequestHeader('Accept-Language', localeHeader);
                    },
                    success: function(data, textStatus, jqXHR) {
                        multiDestinationCampaignSuccess(data, currObj);
                    },
                    error: function(jqXHR, textStatus, errorThrown) {
                        console.log("Multiple destinations : Error fetching data : "+errorThrown);
                    }
                });
            } else {
                if(currObj.attr("data-enable-tempbar")){
                    var items = "<tr><td colspan='2' style='text-align: center;'>No Destinations Available</td></tr>";
                    currObj.find('tbody').empty().append(items);
                    currObj.show();
                    if(currObj.attr("data-enable-tempbar")){
                        var mediumBanner = currObj.closest('.medium-banner');
                        var tempRange = mediumBanner.find(".temp-range");
                        var marginVal = mediumBanner.find('.inner').height() - mediumBanner.find('table').height() - tempRange.outerHeight();
                        tempRange.css('margin-bottom', marginVal);
                    }
                }
            }
        }
    });
}

function formatDialogDate(x){
    var formattedDate = "";
    var mmddyyFormat =  /(\d{1,2})\/(\d{1,2})\/(\d{2})$/;
    if(mmddyyFormat.test(x)){
        var match = mmddyyFormat.exec(x);
        var dateStr = '20' + match[3] + '-' + match[1] + '-' + match[2];
        formattedDate = new Date(dateStr);
    }
    else {
        formattedDate = new Date(x);
    }

    return formattedDate;
}

function getDestFromSlider(currObj, sliderVal){
    var destName = "";
    var tempRange = currObj.find('.temp-range');
    var minTemp = tempRange.attr('data-min-val');
    var maxTemp = tempRange.attr('data-max-val');
    var destCount = parseInt(tempRange.attr('data-dest-count'));
    var apiResp = tempRange.attr('data-temp-api-resp');
    var filteredDest = [];

    if(minTemp && maxTemp && apiResp && destCount){
        JSON.parse(apiResp).resp.forEach(function(item){
            if(filteredDest.length < destCount && parseInt(item.temp) >= parseInt(minTemp) && parseInt(item.temp) <= parseInt(maxTemp) && item.code !== ""){
                filteredDest.push(item.code);
                destName = filteredDest.join(',');
            }
        });
    }

    if(sliderVal !== 'slider'){
        tempRange.find('.ui-slider-handle.min .min-val').hide();
        tempRange.find('.ui-slider-handle.min').on('mouseover',function(event){$(this).find('.min-val').show()});
        tempRange.find('.ui-slider-handle.min').on('mouseout',function(event){$(this).find('.min-val').hide()});

        tempRange.find('.ui-slider-handle.max .max-val').hide();
        tempRange.find('.ui-slider-handle.max').on('mouseover',function(event){$(this).find('.max-val').show()});
        tempRange.find('.ui-slider-handle.max').on('mouseout',function(event){$(this).find('.max-val').hide()});
    }

    return destName;
}

function multiDestinationCampaignSuccess(data, currObj){

    var prefix = currObj.attr("data-prefix") || "";
    var precision = currObj.attr("data-precision") || 0;
    var decimal = currObj.attr("data-decimal") || "";
    var thousand = currObj.attr("data-thousand") || "";
    var suffix = currObj.attr("data-suffix") || "";
    var enable = currObj.attr("data-enable")|| false;
    var tripType = currObj.attr("data-tripType");
    var campaignLabel = currObj.attr("data-campaign-label");
	var isWifiEnabled = currObj.attr("data-wifi-enable");
	var wifiPath = currObj.find('a').attr('href');
	var items = "";
    var formattedPrice="";
    var validPrice = false;
    var originCity = "";
    var today = new Date(new Date().getTime() + (1000 * 60 * 60 * 6));
    for (var key in data) {
        if (data.hasOwnProperty(key)) {
            var val = data[key];
            for (var i = 0; i < val.length; i++) {      // Per searchResponse

                originCity = val[i].originCity.name;

                // Defaults, if no price is returned
                var outBoundDate = today.toISOString(); // today
                var tempDay = new Date();
				tempDay.setDate(today.getDate() + 7);
                var inBoundDate = tempDay.toISOString();    //  + 7 days
                formattedPrice = Granite.I18n.get("aem.commons.book-label"); //"BOOK"
                var totalPrice = 0;

                if (val[i].flightProducts!== undefined && !isNaN(val[i].flightProducts[0].lowestPrice.totalPrice)) {

                    validPrice = true;

                    if(enable){
                        formattedPrice = accounting.formatMoney(val[i].flightProducts[0].lowestPrice.totalPrice, prefix, precision, thousand, decimal) + suffix;
                    }
                    else{
                        formattedPrice = Math.round(val[i].flightProducts[0].lowestPrice.totalPrice) + ' ' + val[i].currency;
                    }

                    outBoundDate = val[i].flightProducts[0].outBoundDate;
                    inBoundDate = val[i].flightProducts[0].inBoundDate;
                    totalPrice = val[i].flightProducts[0].lowestPrice.totalPrice;
                }
                
                var labelWithOrg = Granite.I18n.get("aem.marketing.campaign.one-way-label");

                if(tripType === 'R') {
                    labelWithOrg = Granite.I18n.get("aem.marketing.campaign.return-from-label");

                }

                var item = '<tr tabindex="0" role="link" onClick="onCampaignClick(this, event)" ' +
                'onKeyPress="handleCampaignKeyPress(this, event)" ' +
                'aria-label="' + val[i].originCity.name +' '+ val[i].destinationCity.name + ' ' +labelWithOrg +' '+ formattedPrice + '" ' +
                    '" data-attr-org-airport="' + val[i].originAirport.name +
                        '" data-attr-org="' + val[i].originAirport.code +
                            '" data-attr-org-city="' + val[i].originCity.name +
                                '" data-attr-dest-airport="' + val[i].destinationAirport.name +
                                    '" data-attr-dest="' + val[i].destinationAirport.code +
                                        '" data-attr-dest-city="' + val[i].destinationCity.name +
                                            '" data-attr-type="' + tripType +
                                                '" data-attr-outbound="' + outBoundDate +
                                                    '" data-attr-inbound="' + inBoundDate +
                                                        '" data-attr-price="' + totalPrice +
															'" data-attr-wifi-enable="' + isWifiEnabled +
																'" data-attr-wifi-path="' + wifiPath +
																	'"><td>' + val[i].destinationCity.name 
																	+ '</td><td>' + formattedPrice 
																		+ '</td></tr>';

                items += item;

                if (i === 0) {
                    currObj.show();

                    currObj.find('.campaign-label').empty();
                    var originCityObj = $("<th scope='col'>" + originCity + "</th>");
                    var labelWithOrgObj = $("<th scope='col'>" + labelWithOrg + "</th>");
                    currObj.find('.campaign-label').append(originCityObj, labelWithOrgObj);
                }
            }
        }
    }

    currObj.find('tbody').empty().append(items);

    if (campaignLabel !== '') {
        currObj.find('.campaign-label div.pull-right').html(campaignLabel);
    }

    if(!validPrice){
        currObj.find('.campaign-label div.pull-right').text("");
    }

    if(currObj.attr("data-enable-tempbar")){
        var mediumBanner = currObj.closest('.medium-banner');
        var tempRange = mediumBanner.find(".temp-range");
        var marginVal = mediumBanner.find('.inner').height() - mediumBanner.find('table').height() - tempRange.outerHeight();
        tempRange.css('margin-bottom', marginVal);
    }

}

