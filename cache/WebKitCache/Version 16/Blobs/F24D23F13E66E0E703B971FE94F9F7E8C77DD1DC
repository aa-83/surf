            headerTrackerFlag = false;
        }
        if($('.banner-holder').length > 0 && $('.personalisation-wrapper').length === 0 && $('.multiple-destination-campaign').length === 0 ){
            if(ajaxTrackerFlag){
                bannerTracker();
                ajaxTrackerFlag = false;
            }
        } else {
            $( document ).ajaxStop(function() {
                if(ajaxTrackerFlag){
                    bannerTracker();
                    ajaxTrackerFlag = false;
                }
            });
        }
    }
});

